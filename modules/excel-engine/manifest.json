{
  "key": "excel-engine",
  "name": "Excel 编辑器",
  "icon": "Grid",
  "icon_asset": "",
  "category": "file-editor",
  "component_key": "index.vue",
  "route_prefix": null,
  "permissions": [
    "viewer",
    "editor",
    "admin"
  ],
  "sort_order": 10,
  "default_width": 1100,
  "default_height": 700,
  "min_width": 800,
  "min_height": 500,
  "singleton": false,
  "show_in_launcher": true,
  "show_on_desktop": false,
  "show_in_tray": false,
  "show_in_sidebar": false,
  "window_type": "normal",
  "allow_multiple": true,
  "supported_formats": [
    "xlsx",
    "xls",
    "csv"
  ],
  "editable_formats": [
    "xlsx",
    "csv"
  ],
  "creatable_formats": [
    {
      "extension": "xlsx",
      "label": "Excel 工作簿",
      "mime_type": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
    },
    {
      "extension": "csv",
      "label": "CSV 文件",
      "mime_type": "text/csv"
    }
  ],
  "module_version": "1.0.0",
  "contract_version": "2.0",
  "backend": {
    "enabled": true,
    "router": "backend/router.py"
  },
  "public_actions": [
    {
      "action": "parse",
      "description": "Parse XLSX/CSV files into cell data",
      "parameters": {"file_id": {"type": "int"}},
      "min_role": "viewer"
    },
    {
      "action": "create_workbook",
      "description": "Create a new empty workbook in the database",
      "parameters": {"name": "Workbook name"},
      "min_role": "editor"
    },
    {
      "action": "import_file_to_workbook",
      "description": "Import a file into a database workbook for editing",
      "parameters": {"file_id": "File ID to import"},
      "min_role": "editor"
    },
    {
      "action": "update_range",
      "description": "Update a range of cells",
      "parameters": {"state_key": "Workbook key", "rows": "2D array of values"},
      "min_role": "editor"
    },
    {
      "action": "append_rows",
      "description": "Append rows to the end of a sheet",
      "parameters": {"state_key": "Workbook key", "rows": "2D array of values"},
      "min_role": "editor"
    },
    {
      "action": "undo",
      "description": "Undo the last operation",
      "parameters": {"state_key": "Workbook key"},
      "min_role": "editor"
    },
    {
      "action": "redo",
      "description": "Redo the last undone operation",
      "parameters": {"state_key": "Workbook key"},
      "min_role": "editor"
    },
    {
      "action": "list_history",
      "description": "List operation history for a workbook",
      "parameters": {"state_key": "Workbook key"},
      "min_role": "viewer"
    },
    {
      "action": "list_versions",
      "description": "List saved versions of a workbook",
      "parameters": {"state_key": "Workbook key"},
      "min_role": "viewer"
    },
    {
      "action": "restore_version",
      "description": "Restore a workbook to a saved version",
      "parameters": {"state_key": "Workbook key", "version_id": "Version ID"},
      "min_role": "editor"
    },
    {
      "action": "export_xlsx",
      "description": "Export workbook to XLSX file",
      "parameters": {"state_key": "Workbook key"},
      "min_role": "editor"
    },
    {
      "action": "publish_to_desktop",
      "description": "Publish workbook to desktop",
      "parameters": {"state_key": "Workbook key"},
      "min_role": "editor"
    }
  ]
}